# ============ APPLICATION ============
NODE_ENV=development
PORT=5000

# ============ DATABASE ============
# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:890123d@localhost:5432/socialmedia_db

# ============ JWT AUTHENTICATION ============
# Generate secure secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_here_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_here_change_this_in_production

# Token expiry times
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============ REDIS CACHE ============
# Redis connection for caching and sessions
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ CLOUDINARY (IMAGE UPLOAD) ============
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ============ CLIENT URL ============
# Frontend URL for CORS configuration
CLIENT_URL=http://localhost:3000
